# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in the values.
# NEVER commit .env.local — it holds secrets. (.gitignore covers it.)
# Get these from your Supabase project: Settings → API
# ─────────────────────────────────────────────────────────────

# Public — safe to expose to the browser (used by the client SDK).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The public base URL of the site (used for auth email redirects).
# Local dev: http://localhost:3000 — Production: your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
