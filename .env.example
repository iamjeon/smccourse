# ─────────────────────────────────────────────────────────────
# Copy this file to ".env.local" and fill in the values.
# NEVER commit .env.local — it holds secrets. (.gitignore covers it.)
# Get these from your Supabase project: Settings → API
# ─────────────────────────────────────────────────────────────

# Public — safe to expose to the browser (used by the client SDK).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The public base URL of the site (used for auth email redirects, canonical URLs,
# sitemap, robots, and OG tags).
# Local dev: http://localhost:3000
# Production: https://freesmartmoneycourse.online
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Chat relay (optional — enables 10K+ concurrent chat) ──────
# Leave blank for local dev (falls back to Supabase Realtime).
# Set these when deploying the relay server (see relay/ directory).
NEXT_PUBLIC_RELAY_WS_URL=
RELAY_BROADCAST_URL=
RELAY_SECRET=
